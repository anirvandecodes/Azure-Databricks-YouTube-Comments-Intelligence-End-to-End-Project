                    {"name": "total_comments",        "expression": "`total_comments`"},
                    {"name": "sentiment_score",       "expression": "`sentiment_score`"},
                    {"name": "positive_comments",     "expression": "`positive_comments`"},
                    {"name": "negative_comments",     "expression": "`negative_comments`"},
                    {"name": "neutral_comments",      "expression": "`neutral_comments`"},
                    {"name": "avg_likes_per_comment", "expression": "`avg_likes_per_comment`"},
                    {"name": "total_replies",         "expression": "`total_replies`"},
