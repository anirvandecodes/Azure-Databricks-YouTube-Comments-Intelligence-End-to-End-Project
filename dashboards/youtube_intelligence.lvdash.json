                "y":     {"fieldName": "title",          "scale": {"type": "categorical"},  "displayName": "Video"},
                "color": {"fieldName": "sentiment_type", "scale": {"type": "categorical"},  "displayName": "Sentiment"}
              },
              "frame": {"title": "Positive vs Neutral vs Negative Breakdown per Video", "showTitle": true}
            }
          },
          "position": {"x": 0, "y": 15, "width": 6, "height": 8}
        }
      ]
